# Environment Variables for CrewAI Data Analysis Pipeline

# OPTION 1: OpenRouter (If you want to use Qwen via cloud API)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OPTION 2: Alibaba DashScope (If using Qwen official API)
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OPTION 3: Ollama (Local)
# If using Ollama, you don't need an API key, just ensure Ollama is running `qwen3`

# Search Tool API (For the Researcher Agent to access the web)
# Get a free key at https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here
